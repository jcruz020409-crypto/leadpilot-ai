{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "apps/web/next-env.d.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}

