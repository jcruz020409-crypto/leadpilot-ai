# Application
NODE_ENV=development
APP_URL=http://localhost:3000

# Alibaba Cloud deployment proof
DEPLOYMENT_PROVIDER=Alibaba Cloud
ALIBABA_CLOUD_RUNTIME=ECS Docker
ALIBABA_CLOUD_REGION=

# Database
# Supabase: Project dashboard > Connect > Session Pooler. Replace [YOUR-PASSWORD].
DATABASE_URL=
DATABASE_SSL=true

# Supabase project API values. Reserved for future browser/client features.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Qwen Cloud / Alibaba Cloud Model Studio
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_TEXT_MODEL=qwen-plus
QWEN_REASONING_MODEL=qwen-plus
QWEN_TIMEOUT_MS=60000
LEADPILOT_FORCE_MOCK=false
LEADPILOT_MOCK_WEBSITE=false

# Optional competitor web search
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai

# Email provider
EMAIL_PROVIDER=mock
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_WEBHOOK_SECRET=

# Security
CREDENTIAL_ENCRYPTION_KEY=
SESSION_SECRET=

# Product limits
MAX_LEADS_PER_IMPORT=1000
MAX_AGENT_RETRIES=3
MAX_DAILY_SENDS_PER_WORKSPACE=100
